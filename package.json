{
  "name": "specmatic-stateful-sim",
  "version": "0.1.0",
  "description": "Specmatic Stateful Simulation Engine — CQRS/ES HTTP service simulator via OpenAPI + YAML DSL",
  "license": "MIT",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:bdd": "cucumber-js --config cucumber.cjs",
    "test:all": "npm test && npm run test:bdd",
    "lint": "eslint",
    "format": "prettier --write",
    "start": "tsx src/index.ts",
    "start:example": "tsx examples/run-banking-sim.ts",
    "specmatic-cli:download": "node -e \"require('./tests/integration/specmatic-cli/_helpers/specmatic-binary').ensureSpecmaticJar().then(p => console.log('Cached at:', p)).catch(e => { console.error(e); process.exit(1); })\"",
    "test:contract": "jest --config jest.contract.config.js"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@godaddy/terminus": "^4.12.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.57.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.57.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/instrumentation-express": "^0.46.0",
    "@opentelemetry/instrumentation-http": "^0.57.0",
    "@opentelemetry/instrumentation-pino": "^0.46.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@types/async-retry": "^1.4.9",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "async-retry": "^1.3.3",
    "body-parser": "^1.20.3",
    "esbuild": "^0.28.0",
    "express": "^4.21.2",
    "js-yaml": "^4.1.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "uuidv7": "^1.0.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.3.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "eslint": "^9.18.0",
    "fast-check": "^3.23.2",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
